# ---------------------------------------------------------------------------
# OrangeHRM TEA Demo - Environment Configuration
# ---------------------------------------------------------------------------
# Copy this file to ".env" and adjust values as needed:
#     cp .env.example .env        (macOS/Linux)
#     Copy-Item .env.example .env (Windows PowerShell)
#
# In CI these values are injected from repository secrets
# (see .github/workflows/test.yml). NEVER commit a real .env file.
# ---------------------------------------------------------------------------

# Base URL of the system under test
BASE_URL=https://opensource-demo.orangehrmlive.com

# Demo credentials (public, provided by OrangeHRM demo site)
ADMIN_USER=Admin
ADMIN_PASSWORD=admin123
